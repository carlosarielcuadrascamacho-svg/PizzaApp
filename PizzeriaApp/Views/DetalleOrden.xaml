<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.DetalleOrden"
             Title="Detalle de Orden"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Header de la Orden -->
            <Border Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="lblOrdenId" Text="#000000" FontSize="28" FontAttributes="Bold" TextColor="#FF4B3A" />
                        <Label x:Name="lblMesa" Text="Mesa: --" FontSize="14" TextColor="#757575" />
                        <Label x:Name="lblFecha" Text="" FontSize="12" TextColor="#AAA" />
                        <Label x:Name="lblTiempo" Text="" FontSize="12" TextColor="#AAA" />
                    </VerticalStackLayout>
                    <Border x:Name="badgeEstado" Grid.Column="1" Padding="16,8" BackgroundColor="#FF4B3A" StrokeShape="RoundRectangle 14" StrokeThickness="0" VerticalOptions="Start">
                        <Label x:Name="lblEstado" Text="Pendiente" FontSize="12" FontAttributes="Bold" TextColor="White" />
                    </Border>
                </Grid>
            </Border>

            <!-- Productos Pedidos -->
            <Border Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🛒 PRODUCTOS PEDIDOS" FontSize="12" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" />
                    <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" />
                    <VerticalStackLayout x:Name="listaProductos" Spacing="10" />

                    <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" />
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TOTAL" FontSize="14" FontAttributes="Bold" TextColor="#757575" VerticalOptions="Center" />
                        <Label x:Name="lblTotal" Grid.Column="1" Text="$0.00" FontSize="24" FontAttributes="Bold" TextColor="#00C853" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Comentario del Cliente -->
            <Border x:Name="panelComentario" Padding="20" BackgroundColor="#FFF8E1" StrokeThickness="0" StrokeShape="RoundRectangle 24" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="💬 COMENTARIO DEL CLIENTE" FontSize="12" FontAttributes="Bold" TextColor="#F57F17" CharacterSpacing="1.5" />
                    <BoxView HeightRequest="1" BackgroundColor="#FFE082" />
                    <Label x:Name="lblComentario" Text="" FontSize="15" TextColor="#795548" LineHeight="1.4" />
                </VerticalStackLayout>
            </Border>

            <!-- Datos del Cliente -->
            <Border Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="👤 DATOS DEL CLIENTE" FontSize="12" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" />
                    <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" />

                    <!-- Cargando -->
                    <ActivityIndicator x:Name="loadingCliente" IsRunning="True" IsVisible="True" Color="#FF4B3A" HorizontalOptions="Center" />

                    <VerticalStackLayout x:Name="panelDatosCliente" IsVisible="False" Spacing="15">
                        <!-- Nombre -->
                        <Grid ColumnDefinitions="40, *" RowSpacing="2">
                            <Label Grid.Column="0" Text="👤" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="NOMBRE" FontSize="10" TextColor="#AAA" CharacterSpacing="1" />
                                <Label x:Name="lblClienteNombre" Text="--" FontSize="16" FontAttributes="Bold" TextColor="#1A1A1A" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Teléfono -->
                        <Grid ColumnDefinitions="40, *" RowSpacing="2">
                            <Label Grid.Column="0" Text="📞" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="TELÉFONO" FontSize="10" TextColor="#AAA" CharacterSpacing="1" />
                                <Label x:Name="lblClienteTelefono" Text="--" FontSize="16" TextColor="#1A1A1A" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Correo -->
                        <Grid ColumnDefinitions="40, *" RowSpacing="2">
                            <Label Grid.Column="0" Text="✉️" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="CORREO" FontSize="10" TextColor="#AAA" CharacterSpacing="1" />
                                <Label x:Name="lblClienteEmail" Text="--" FontSize="16" TextColor="#1A1A1A" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Dirección -->
                        <Grid ColumnDefinitions="40, *" RowSpacing="2">
                            <Label Grid.Column="0" Text="📍" FontSize="20" VerticalOptions="Start" />
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="DIRECCIÓN" FontSize="10" TextColor="#AAA" CharacterSpacing="1" />
                                <Label x:Name="lblClienteDireccion" Text="--" FontSize="15" TextColor="#1A1A1A" LineHeight="1.3" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Acciones -->
            <Border x:Name="panelAcciones" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="⚡ ACCIONES" FontSize="12" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" />
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <Button Grid.Column="0" x:Name="btnPreparando" Text="🔥 PREPARANDO" Clicked="OnCambiarEstado" CommandParameter="En preparación"
                                BackgroundColor="#FFF3E0" TextColor="#E65100" CornerRadius="16" FontAttributes="Bold" FontSize="14" HeightRequest="55" />
                        <Button Grid.Column="1" x:Name="btnEntregado" Text="✓ ENTREGADO" Clicked="OnCambiarEstado" CommandParameter="Entregado"
                                BackgroundColor="#00C853" TextColor="White" CornerRadius="16" FontAttributes="Bold" FontSize="14" HeightRequest="55" />
                    </Grid>
                    <Button x:Name="btnCancelar" Text="✕ CANCELAR ORDEN" Clicked="OnCancelarOrden"
                            BackgroundColor="#FDECEA" TextColor="#FF4B3A" CornerRadius="16" FontAttributes="Bold" FontSize="14" HeightRequest="50" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
