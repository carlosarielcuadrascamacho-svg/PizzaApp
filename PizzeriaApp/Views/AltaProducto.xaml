<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.AltaProducto"
             Title="Alta de Producto"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="25">
            <!-- Título -->
            <Label Text="Crear Nueva Pizza" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#B71C1C" />

            <!-- Área unificada de Imagen -->
            <Frame HeightRequest="220" CornerRadius="20" BackgroundColor="#FFF8E1" HasShadow="True" Padding="0" IsClippedToBounds="True" BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAñadirFotoClicked" />
                </Frame.GestureRecognizers>
                <Grid>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" x:Name="vwPlaceholder">
                        <Label Text="📷" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Tocar para añadir foto" TextColor="#FF8F00" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Image x:Name="imgPreview" Aspect="AspectFill" IsVisible="false"/>
                </Grid>
            </Frame>

            <Button Text="📷 Seleccionar Imagen" Clicked="OnAñadirFotoClicked" BackgroundColor="#E53935" TextColor="White" FontAttributes="Bold" CornerRadius="12" Margin="0,-10,0,10"/>

            <!-- Formulario Premium -->
            <Border StrokeThickness="0" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="15">
                    <Entry x:Name="txtNombre" Placeholder="Nombre del Producto" TextColor="#333" FontSize="16" />
                    <BoxView HeightRequest="1" Color="#EEEEEE" />
                    <Entry x:Name="txtPrecio" Placeholder="Precio ($)" Keyboard="Numeric" TextColor="#333" FontSize="16" />
                    <BoxView HeightRequest="1" Color="#EEEEEE" />
                    <Editor x:Name="txtDescripcion" Placeholder="Descripción corta..." HeightRequest="100" TextColor="#666" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- Botón Guardar -->
            <Button x:Name="btnGuardar"
                    Text="Guardar Producto" 
                    BackgroundColor="#4CAF50" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    FontSize="18"
                    CornerRadius="25"
                    HeightRequest="55"
                    Margin="0,10,0,20"
                    Clicked="OnGuardarClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
