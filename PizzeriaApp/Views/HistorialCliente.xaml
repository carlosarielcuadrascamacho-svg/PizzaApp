<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="PizzeriaApp.Views.HistorialCliente"
             Title="Mis Pedidos"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="5">
                <Label Text="Tu Historial" FontSize="26" FontAttributes="Bold" TextColor="#1A1A1A" />
                <Label Text="Revisa tus órdenes pasadas" FontSize="13" TextColor="#757575" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" x:Name="ListaHistorial" Margin="15,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="20" Margin="0,0,0,20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding IdVisible}" FontSize="18" FontAttributes="Bold" TextColor="#FF4B3A" />
                                    <Label Text="{Binding Fecha, StringFormat='{0:dd MMM, HH:mm}'}" FontSize="13" TextColor="#757575" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                    <Label Text="{Binding Total, StringFormat='{0:C}'}" FontSize="20" FontAttributes="Bold" TextColor="#00C853" HorizontalOptions="End" />
                                    <Label Text="{Binding Estado}" FontSize="12" FontAttributes="Bold" TextColor="#FF4B3A" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Grid>

                            <syncfusion:SfDataGrid ItemsSource="{Binding Detalles}"
                                                   AutoGenerateColumnsMode="None"
                                                   HeaderRowHeight="0" RowHeight="35"
                                                   SelectionMode="None" GridLinesVisibility="None"
                                                   HeaderGridLinesVisibility="None" BackgroundColor="Transparent"
                                                   HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
                                <syncfusion:SfDataGrid.Columns>
                                    <syncfusion:DataGridTextColumn MappingName="Cantidad" Width="45" />
                                    <syncfusion:DataGridTextColumn MappingName="NombrePlatillo" />
                                    <syncfusion:DataGridTextColumn MappingName="Comentarios" />
                                </syncfusion:SfDataGrid.Columns>
                            </syncfusion:SfDataGrid>

                            <Button Text="CANCELAR PEDIDO" 
                                    IsVisible="{Binding IsNotCancelled}"
                                    Clicked="OnCancelarClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#FDECEA" TextColor="#FF4B3A" 
                                    CornerRadius="15" HeightRequest="45" FontAttributes="Bold" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
