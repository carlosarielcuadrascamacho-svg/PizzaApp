<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.HistorialCliente"
             Title="Mis Pedidos"
             BackgroundColor="#F9F9F9">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Margin="15" Padding="15" StrokeThickness="0" BackgroundColor="#E53935" StrokeShape="RoundRectangle 15">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="📜" FontSize="32" VerticalOptions="Center"/>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Historial Culinario" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Tus compras pasadas en tiempo real" FontSize="14" TextColor="#FFCDD2" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" x:Name="ListaHistorial" Margin="10,0,10,10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="15" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15" Margin="0,50,0,0">
                    <Label Text="🍕" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="Aún no tienes pedidos." FontSize="18" TextColor="Gray" FontAttributes="Bold"/>
                    <Label Text="Anímate a explorar nuestro menú." FontSize="14" TextColor="Silver"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="15" CornerRadius="12" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="10">
                            <!-- Fecha y Estado -->
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Fecha, StringFormat='{0:dd MMMM yyyy HH:mm}'}" FontSize="14" TextColor="Gray" />
                            
                            <!-- Indicador Visual Cromático según Estado -->
                            <Frame Grid.Row="0" Grid.Column="1" Padding="8,4" CornerRadius="8" HasShadow="False" BackgroundColor="#FFF8E1" BorderColor="Transparent">
                                <Label Text="{Binding Estado}" FontSize="12" FontAttributes="Bold" TextColor="#FF8F00"/>
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Estado}" Value="Entregado">
                                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                    </DataTrigger>
                                </Frame.Triggers>
                            </Frame>

                            <!-- Folio y Total -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Id, StringFormat='Orden #{0}'}" FontSize="12" TextColor="Silver" LineBreakMode="TailTruncation" />
                                <Label Text="Subtotal pagado" FontSize="12" TextColor="#888"/>
                            </VerticalStackLayout>

                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Total, StringFormat='{0:C}'}" FontSize="18" TextColor="#D32F2F" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
