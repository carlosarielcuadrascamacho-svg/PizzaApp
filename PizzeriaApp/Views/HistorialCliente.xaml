<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.HistorialCliente"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             Title="Mis Pedidos"
             BackgroundColor="#F5F6F8">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IndexToColorConverter x:Key="IndexToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="25,30,25,15" Spacing="4">
            <Label Text="Mis Pedidos" FontSize="32" FontAttributes="Bold" TextColor="#2D2D2D" />
            <Label Text="Historial de tus antojos" FontSize="14" TextColor="#9E9E9E" />
        </VerticalStackLayout>

        <syncfusion:SfDataGrid Grid.Row="1" 
                               x:Name="ListaHistorialGrid" 
                               Margin="20,0"
                               AutoGenerateColumnsMode="None"
                               ColumnWidthMode="Fill" 
                               HeaderRowHeight="0"
                               QueryRowHeight="ListaHistorialGrid_QueryRowHeight"
                               SelectionMode="None" 
                               GridLinesVisibility="None" 
                               BackgroundColor="Transparent">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTemplateColumn MappingName="Id">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,20" 
                                    Padding="20" 
                                    BackgroundColor="White" 
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="0,8" Radius="15" Opacity="0.05" />
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="15">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding IdVisible, StringFormat='Orden #{0}'}" 
                                                   FontSize="17" FontAttributes="Bold" TextColor="#1A1A1A" />
                                            <Label Text="{Binding FechaLocal, StringFormat='{0:dd MMM yyyy • HH:mm}'}" 
                                                   FontSize="12" TextColor="#9E9E9E" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1" 
                                                Padding="10,4" 
                                                BackgroundColor="{Binding ColorEstado}" 
                                                StrokeShape="RoundRectangle 8"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding Estado}" 
                                                   FontSize="11" 
                                                   FontAttributes="Bold" 
                                                   TextColor="White" 
                                                   VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Stepper de Estado Premium -->
                                    <Grid ColumnDefinitions="*, *, *, *" Margin="0,10">
                                        <!-- Línea de Progreso Base (Gris) -->
                                        <BoxView Grid.ColumnSpan="4" HeightRequest="4" BackgroundColor="#F5F5F5" VerticalOptions="Center" Margin="30,0" CornerRadius="2" />
                                        
                                        <!-- Línea de Progreso Activa (Dinámica si fuera posible, o solo estilizada) -->

                                        <!-- Paso 1: Recibido -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                                            <Border HeightRequest="32" WidthRequest="32" StrokeShape="RoundRectangle 16" StrokeThickness="0" 
                                                    BackgroundColor="{Binding ProgressIndex, Converter={StaticResource IndexToColorConverter}, ConverterParameter=1}">
                                                <Label Text="🕒" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <Label Text="Recibido" FontSize="9" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#757575" />
                                        </VerticalStackLayout>

                                        <!-- Paso 2: Cocina -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                                            <Border HeightRequest="32" WidthRequest="32" StrokeShape="RoundRectangle 16" StrokeThickness="0" 
                                                    BackgroundColor="{Binding ProgressIndex, Converter={StaticResource IndexToColorConverter}, ConverterParameter=2}">
                                                <Label Text="🔥" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <Label Text="Cocina" FontSize="9" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#757575" />
                                        </VerticalStackLayout>

                                        <!-- Paso 3: Listo -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                                            <Border HeightRequest="32" WidthRequest="32" StrokeShape="RoundRectangle 16" StrokeThickness="0" 
                                                    BackgroundColor="{Binding ProgressIndex, Converter={StaticResource IndexToColorConverter}, ConverterParameter=3}">
                                                <Label Text="✅" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <Label Text="Listo" FontSize="9" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#757575" />
                                        </VerticalStackLayout>

                                        <!-- Paso 4: Entregado -->
                                        <VerticalStackLayout Grid.Column="3" Spacing="5" HorizontalOptions="Center">
                                            <Border HeightRequest="32" WidthRequest="32" StrokeShape="RoundRectangle 16" StrokeThickness="0" 
                                                    BackgroundColor="{Binding ProgressIndex, Converter={StaticResource IndexToColorConverter}, ConverterParameter=4}">
                                                <Label Text="🚚" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <Label Text="Entregado" FontSize="9" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#757575" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Detalles}" Spacing="8">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="30, *, Auto">
                                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x'}" 
                                                           TextColor="#FF4B3A" FontAttributes="Bold" FontSize="14" />
                                                    <VerticalStackLayout Grid.Column="1">
                                                        <Label Text="{Binding NombrePlatillo}" TextColor="#444444" FontSize="14" FontAttributes="Bold"/>
                                                        <Label Text="{Binding Comentarios}" IsVisible="{Binding TieneComentarios}"
                                                               FontSize="11" TextColor="#9E9E9E" FontAttributes="Italic"/>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="Total pagado" FontSize="11" TextColor="#9E9E9E" />
                                            <Label Text="{Binding Total, StringFormat='{0:C}'}" 
                                                   FontSize="20" FontAttributes="Bold" TextColor="#2D2D2D" />
                                        </VerticalStackLayout>

                                        <Button Grid.Column="1"
                                                Text="CANCELAR" 
                                                IsVisible="{Binding IsNotCancelled}"
                                                Clicked="OnCancelarClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#FF4B3A" 
                                                TextColor="White" 
                                                FontSize="12"
                                                CornerRadius="12" 
                                                Padding="20,0"
                                                HeightRequest="40" 
                                                FontAttributes="Bold"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>