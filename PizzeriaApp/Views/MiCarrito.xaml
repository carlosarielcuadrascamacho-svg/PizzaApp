<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.MiCarrito"
             Title="Confirmar Orden"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" BackgroundColor="#FDFDFD">
        <!-- Header minimalista -->
        <VerticalStackLayout Grid.Row="0" Padding="25,30,25,10" Spacing="5">
            <Label Text="Mi Carrito" FontSize="28" FontAttributes="Bold" TextColor="#1A1A1A" />
            <Label Text="Personaliza y confirma tu orden abajo" FontSize="14" TextColor="#757575" />
        </VerticalStackLayout>

        <!-- Empty state (se muestra si no hay items) -->
        <VerticalStackLayout x:Name="emptyState" Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="25" IsVisible="False">
            <Border HeightRequest="160" WidthRequest="160" StrokeShape="RoundRectangle 80" StrokeThickness="0" BackgroundColor="#FDF2F1" HorizontalOptions="Center">
                <Label Text="🛍️" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <VerticalStackLayout Spacing="8">
                <Label Text="Tu carrito está vacío" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1A1A1A" />
                <Label Text="¡Parece que aún no has elegido tu pizza favorita!" FontSize="14" TextColor="#757575" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="40,0" />
            </VerticalStackLayout>
            <Button Text="EXPLORAR MENÚ" BackgroundColor="#FF4B3A" TextColor="White" CornerRadius="20" HeightRequest="55" Padding="40,0" FontAttributes="Bold" Clicked="OnRegresarMenuClicked">
                <Button.Shadow>
                    <Shadow Brush="#FF4B3A" Offset="0,8" Radius="15" Opacity="0.3" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <!-- Lista de Productos en el Carrito -->
        <CollectionView Grid.Row="1" x:Name="ListaCarrito" Margin="15,5" IsVisible="True">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 20" Margin="5,0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <!-- Foto del Producto -->
                            <Border Grid.Column="0" HeightRequest="75" WidthRequest="75" StrokeShape="RoundRectangle 15" StrokeThickness="0">
                                <Image Source="{Binding Producto.ImagenBase64, Converter={StaticResource Base64Converter}}" Aspect="AspectFill" />
                            </Border>

                            <!-- Info y Stepper -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Producto.Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#1A1A1A" />
                                <Label Text="{Binding Producto.Precio, StringFormat='{0:C} c/u'}" FontSize="12" TextColor="#757575" />
                                
                                <!-- Stepper de Cantidad personalizado -->
                                <Border BackgroundColor="#F8F9FA" StrokeShape="RoundRectangle 12" StrokeThickness="0" HorizontalOptions="Start" Padding="5">
                                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                                        <Button Text="-" Clicked="OnDisminuirCantidadClicked" CommandParameter="{Binding .}"
                                                HeightRequest="32" WidthRequest="32" CornerRadius="8" Padding="0"
                                                BackgroundColor="White" TextColor="#1A1A1A" FontSize="16">
                                            <Button.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                                            </Button.Shadow>
                                        </Button>
                                        
                                        <Label Text="{Binding Cantidad}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="#1A1A1A" WidthRequest="20" HorizontalTextAlignment="Center" />
                                        
                                        <Button Text="+" Clicked="OnAumentarCantidadClicked" CommandParameter="{Binding .}"
                                                HeightRequest="32" WidthRequest="32" CornerRadius="8" Padding="0"
                                                BackgroundColor="#FF4B3A" TextColor="White" FontSize="16">
                                            <Button.Shadow>
                                                <Shadow Brush="#FF4B3A" Offset="0,4" Radius="8" Opacity="0.3" />
                                            </Button.Shadow>
                                        </Button>
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Eliminar -->
                            <Button Grid.Column="2" 
                                    Text="✕" Clicked="OnEliminarItemClicked" CommandParameter="{Binding .}"
                                    BackgroundColor="#FFF5F5" TextColor="#FF4B3A" FontAttributes="Bold"
                                    CornerRadius="12" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Checkout Section Premium con Desglose -->
        <Border Grid.Row="2" Padding="25,25,25,35" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 32,32,0,0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-10" Radius="20" Opacity="0.08" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="20">

                <VerticalStackLayout Spacing="12">
                    <!-- Mesa -->
                    <Border x:Name="PanelAdminMesa" StrokeThickness="1" Stroke="#F0F0F0" BackgroundColor="#F8F9FA" StrokeShape="RoundRectangle 16" Padding="15,0" HeightRequest="55">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Text="📍" VerticalOptions="Center" Margin="0,0,10,0" />
                            <Entry Grid.Column="1" x:Name="txtMesaCliente" Placeholder="Mesa o Nombre del Cliente" BackgroundColor="Transparent" TextColor="#1A1A1A" />
                        </Grid>
                    </Border>

                    <!-- Comentario -->
                    <Border StrokeThickness="1" Stroke="#F0F0F0" BackgroundColor="#F8F9FA" StrokeShape="RoundRectangle 16" Padding="15,8" HeightRequest="80">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Text="💬" VerticalOptions="Start" Margin="0,5,10,0" />
                            <Editor Grid.Column="1" x:Name="txtComentario" Placeholder="Instrucciones de cocina..." BackgroundColor="Transparent" TextColor="#1A1A1A" AutoSize="TextChanges" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Resumen de Costos (NUEVO) -->
                <VerticalStackLayout Spacing="8" Margin="0,5">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Subtotal" TextColor="#757575" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Source={x:Reference lblTotalCosto}, Path=Text}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Envío / Servicio" TextColor="#757575" FontSize="14" />
                        <Label Grid.Column="1" Text="GRATIS" TextColor="#4CAF50" FontSize="12" FontAttributes="Bold" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,5" />
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="TOTAL A PAGAR" TextColor="#1A1A1A" FontSize="16" FontAttributes="Bold" />
                        <Label Grid.Column="1" x:Name="lblTotalCosto" Text="$0.00" FontSize="20" FontAttributes="Bold" TextColor="#FF4B3A" />
                    </Grid>
                </VerticalStackLayout>
                
                <Button Text="CONFIRMAR ORDEN" Clicked="OnConfirmarOrdenClicked" 
                        BackgroundColor="#FF4B3A" TextColor="White" HeightRequest="65" 
                        Padding="25,0" CornerRadius="22" FontAttributes="Bold" FontSize="16">
                    <Button.Shadow>
                        <Shadow Brush="#FF4B3A" Offset="0,10" Radius="20" Opacity="0.4" />
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
