<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.ColaCocina"
             Title="Cola de Cocina"
             BackgroundColor="#ECEFF1">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Margin="15" Padding="15" StrokeThickness="0" BackgroundColor="#1565C0" StrokeShape="RoundRectangle 15">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="👨‍🍳" FontSize="32" VerticalOptions="Center"/>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Kanban Cocina" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Despacha los pedidos entrantes" FontSize="14" TextColor="#BBDEFB" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" x:Name="ListaPedidos" Margin="10,0,10,10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="15" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="15" CornerRadius="12" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                <Label Text="🔴" FontSize="12" VerticalOptions="Center" IsVisible="{Binding Estado, Converter={StaticResource EqualConverter}, ConverterParameter='En preparación'}"/>
                                <Label Text="{Binding Id, StringFormat='Orden {0}'}" FontSize="16" FontAttributes="Bold" TextColor="#333" LineBreakMode="TailTruncation" WidthRequest="200" />
                            </HorizontalStackLayout>
                            
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Fecha, StringFormat='{0:HH:mm}'}" FontSize="14" TextColor="Gray" HorizontalOptions="End" />
                            
                            <!-- SubQuery (No contamos con ORM directo para Items anidados así que pondremos un helper de resumen) -->
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Total, StringFormat='Venta Confirmada: {0:C}'}" FontSize="14" TextColor="#1565C0" Margin="0,10,0,15" FontAttributes="Bold"/>

                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                    Text="✅ DESPACHAR PEDIDO" 
                                    BackgroundColor="#4CAF50" 
                                    TextColor="White" 
                                    FontAttributes="Bold" 
                                    CornerRadius="20"
                                    Clicked="OnDespacharClicked"
                                    BindingContext="{Binding .}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
