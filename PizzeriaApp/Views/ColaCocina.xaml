<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.ColaCocina"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             Title="Panel de Cocina"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="Pedidos Activos" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="lblContador" Text="Cola de Cocina en Tiempo Real" FontSize="13" TextColor="#FF4B3A" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="⟳" FontSize="20" Clicked="OnRefreshClicked"
                        BackgroundColor="#F5F5F5" TextColor="#FF4B3A" WidthRequest="45" HeightRequest="45"
                        CornerRadius="22" BorderWidth="1" BorderColor="#EEEEEE" />
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ActivityIndicator x:Name="loadingIndicator" Grid.Row="1" IsRunning="False" IsVisible="False"
                           Color="#FF4B3A" VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- Empty state -->
        <VerticalStackLayout x:Name="emptyState" Grid.Row="1" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Label Text="🍕" FontSize="60" HorizontalOptions="Center" />
            <Label Text="No hay pedidos pendientes" FontSize="18" FontAttributes="Bold" TextColor="#757575" HorizontalOptions="Center" />
            <Label Text="Los nuevos pedidos aparecerán aquí" FontSize="13" TextColor="#AAA" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Lista de Pedidos (Syncfusion DataGrid) -->
        <syncfusion:SfDataGrid Grid.Row="1" x:Name="ListaPedidosGrid" Margin="15,0"
                               AutoGenerateColumnsMode="None"
                               ColumnWidthMode="Fill" RowHeight="380" HeaderRowHeight="0"
                               SelectionMode="None" GridLinesVisibility="None" BackgroundColor="Transparent">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTemplateColumn MappingName="Id">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="20" Margin="5,0,5,15" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPedidoTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="12">
                                    <!-- Header del pedido: ID + Mesa + Estado -->
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding IdVisible}" FontSize="18" FontAttributes="Bold" TextColor="#FF4B3A" />
                                            <Label Text="{Binding MesaVisible}" FontSize="13" TextColor="#757575" />
                                            <Label Text="{Binding TiempoRelativo}" FontSize="11" TextColor="#AAA" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1" Padding="12,6" BackgroundColor="{Binding ColorEstado}" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Start">
                                            <Label Text="{Binding Estado}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                        </Border>
                                    </Grid>

                                    <!-- Separador -->
                                    <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" />

                                    <!-- Detalles del pedido como lista simple -->
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Detalles}" Spacing="6">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="45, *" Padding="5,2">
                                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='x{0}'}" FontSize="14" FontAttributes="Bold" TextColor="#FF4B3A" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="{Binding NombrePlatillo}" FontSize="14" TextColor="#333" VerticalOptions="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <!-- Comentario del cliente -->
                                    <Border x:Name="borderComentario" Padding="12,10" BackgroundColor="#FFF8E1" StrokeShape="RoundRectangle 10" StrokeThickness="0" IsVisible="{Binding TieneComentario}">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="💬" FontSize="14" VerticalOptions="Start" />
                                            <Label Text="{Binding Comentario}" FontSize="13" TextColor="#795548" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Total -->
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="Total:" FontSize="13" TextColor="#757575" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Total, StringFormat='${0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="#1A1A1A" VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Hint para ver detalle -->
                                    <Label Text="Toca para ver detalle completo ›" FontSize="11" TextColor="#BDBDBD" HorizontalOptions="Center" />

                                    <!-- Botones de acción - solo visibles si el pedido está activo -->
                                    <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10" IsVisible="{Binding IsNotCancelled}">
                                        <Button Grid.Column="0" Text="🔥 PREPARANDO" Clicked="OnEstadoClicked" CommandParameter="En preparación"
                                                BackgroundColor="#FFF3E0" TextColor="#E65100" CornerRadius="12" FontAttributes="Bold" FontSize="12"
                                                HeightRequest="44" />
                                        <Button Grid.Column="1" Text="✓ LISTO" Clicked="OnEstadoClicked" CommandParameter="Entregado"
                                                BackgroundColor="#00C853" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12"
                                                HeightRequest="44" />
                                        <Button Grid.Column="2" Text="✕" Clicked="OnCancelarClicked"
                                                BackgroundColor="#FDECEA" TextColor="#FF4B3A" CornerRadius="12"
                                                WidthRequest="44" HeightRequest="44" FontSize="16" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>
