<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.ColaCocina"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             Title="Panel de Cocina"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">
        <!-- Header con Filtros -->
        <VerticalStackLayout Grid.Row="0" Margin="20,15,20,5" Spacing="15">
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Panel de Cocina" FontSize="26" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label x:Name="lblContador" Text="Cola de Cocina en Tiempo Real" FontSize="14" TextColor="#FF4B3A" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="⟳" FontSize="22" Clicked="OnRefreshClicked"
                        BackgroundColor="Transparent" TextColor="#FF4B3A" WidthRequest="50" HeightRequest="50" />
            </Grid>

            <!-- Filtros de Estado (Pill style) -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Todos" Clicked="OnFilterClicked" CommandParameter="Todos"
                        BackgroundColor="#FFEBE8" TextColor="#FF4B3A" CornerRadius="20" HeightRequest="36" Padding="15,0" FontSize="12" />
                <Button Text="En cola" Clicked="OnFilterClicked" CommandParameter="Ordenado"
                        BackgroundColor="#F0F0F0" TextColor="#607D8B" CornerRadius="20" HeightRequest="36" Padding="15,0" FontSize="12" />
                <Button Text="En fuego" Clicked="OnFilterClicked" CommandParameter="En preparación"
                        BackgroundColor="#FFF3E0" TextColor="#E65100" CornerRadius="20" HeightRequest="36" Padding="15,0" FontSize="12" />
                <Button Text="Listos" Clicked="OnFilterClicked" CommandParameter="Listo"
                        BackgroundColor="#E8F5E9" TextColor="#2E7D32" CornerRadius="20" HeightRequest="36" Padding="15,0" FontSize="12" />
            </HorizontalStackLayout>
            
            <!-- Panel de Resumen Consolidado (NUEVO) -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,5">
                <HorizontalStackLayout x:Name="LayoutResumen" Spacing="10" Padding="0,5">
                    <!-- Se llena dinámicamente desde el code-behind -->
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- Loading indicator -->
        <ActivityIndicator x:Name="loadingIndicator" Grid.Row="1" IsRunning="False" IsVisible="False"
                           Color="#FF4B3A" VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- Empty state -->
        <VerticalStackLayout x:Name="emptyState" Grid.Row="1" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
            <Label Text="👨‍🍳" FontSize="70" HorizontalOptions="Center" />
            <Label Text="¡Todo bajo control!" FontSize="20" FontAttributes="Bold" TextColor="#1A1A1A" HorizontalOptions="Center" />
            <Label Text="No hay pedidos pendientes por ahora." FontSize="14" TextColor="#757575" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Lista de Pedidos (Syncfusion DataGrid) -->
        <syncfusion:SfDataGrid Grid.Row="1" x:Name="ListaPedidosGrid" Margin="15,5"
                               AutoGenerateColumnsMode="None"
                               ColumnWidthMode="Fill" RowHeight="340" HeaderRowHeight="0"
                               SelectionMode="None" GridLinesVisibility="None" BackgroundColor="Transparent">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTemplateColumn MappingName="Id">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Diseño tipo Ticket de Cocina -->
                            <Border Padding="0" Margin="5,8" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                                </Border.Shadow>
                                
                                <Grid ColumnDefinitions="8, *">
                                    <!-- Barra lateral de estado -->
                                    <BoxView Grid.Column="0" BackgroundColor="{Binding ColorEstado}" WidthRequest="8" />
                                    
                                    <VerticalStackLayout Grid.Column="1" Padding="15" Spacing="10">
                                        <!-- Header del ticket -->
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnTicketTapped" />
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Label Text="{Binding IdVisible}" FontSize="20" FontAttributes="Bold" TextColor="#1A1A1A" />
                                                <Label Text="{Binding MesaVisible}" FontSize="15" TextColor="#757575" FontAttributes="Bold" />
                                            </VerticalStackLayout>
                                            
                                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Start" Spacing="5">
                                                <Border Padding="10,4" BackgroundColor="{Binding ColorEstado}" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                                    <Label Text="{Binding Estado}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                                </Border>
                                                
                                                <!-- Alerta de Tiempo (NUEVO) -->
                                                <Border IsVisible="{Binding EsUrgente}" Padding="8,2" BackgroundColor="#FFEBE8" Stroke="#FF4B3A" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                                    <HorizontalStackLayout Spacing="5">
                                                        <Label Text="⚠️" FontSize="10" VerticalOptions="Center" />
                                                        <Label Text="RETRASADO" FontSize="9" FontAttributes="Bold" TextColor="#FF4B3A" VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                </Border>

                                                <Label Text="{Binding TiempoRelativo}" FontSize="11" TextColor="#AAA" HorizontalOptions="End" Margin="0,5,0,0" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Sección Expandible: Info del Cliente -->
                                        <Border IsVisible="{Binding IsExpanded}" Padding="15" BackgroundColor="#F8F9FA" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                            <VerticalStackLayout Spacing="5">
                                                <Label Text="DATOS DEL CLIENTE" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1" />
                                                <Label Text="{Binding Cliente.Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#1A1A1A" />
                                                <Label Text="{Binding Cliente.Telefono, StringFormat='📞 {0}'}" FontSize="14" TextColor="#1A1A1A" />
                                                <Label Text="{Binding Cliente.Direccion, StringFormat='🏠 {0}'}" FontSize="13" TextColor="#757575" MaxLines="2" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,2" />

                                        <!-- Productos (Cuerpo del ticket) -->
                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Detalles}" Spacing="5">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTicketTapped" />
                                            </VerticalStackLayout.GestureRecognizers>
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                                                        <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x'}" FontSize="16" FontAttributes="Bold" TextColor="#FF4B3A" />
                                                        <Label Grid.Column="1" Text="{Binding NombrePlatillo}" FontSize="16" TextColor="#333" FontAttributes="Bold" />
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>

                                        <!-- Comentario crítico -->
                                        <Border Padding="10" BackgroundColor="#FFFDE7" StrokeShape="RoundRectangle 8" IsVisible="{Binding TieneComentario}">
                                            <Label Text="{Binding Comentario}" FontSize="13" TextColor="#795548" FontAttributes="Italic" />
                                        </Border>

                                        <!-- Footer y Acciones -->
                                        <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                            <Button Grid.Column="0" 
                                                    Text="{Binding TextoBotonSiguiente}" 
                                                    CommandParameter="{Binding SiguienteEstado}"
                                                    Clicked="OnEstadoClicked"
                                                    BackgroundColor="{Binding ColorEstado}" 
                                                    TextColor="White" 
                                                    CornerRadius="12" 
                                                    FontAttributes="Bold" 
                                                    HeightRequest="48"
                                                    Margin="0,0,10,0" />
                                            
                                            <Button Grid.Column="1" 
                                                    Text="✕" 
                                                    Clicked="OnCancelarClicked"
                                                    BackgroundColor="#F5F5F5" 
                                                    TextColor="#757575" 
                                                    CornerRadius="12" 
                                                    WidthRequest="48" 
                                                    HeightRequest="48" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>
