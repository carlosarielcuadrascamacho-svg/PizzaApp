<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="PizzeriaApp.Views.ColaCocina"
             Title="Panel de Cocina"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Pedidos Activos" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                <Label Text="Cola de Cocina en Tiempo Real" FontSize="13" TextColor="#FF4B3A" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" x:Name="ListaPedidos" Margin="15,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="20" Margin="0,0,0,20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding IdVisible}" FontSize="18" FontAttributes="Bold" TextColor="#FF4B3A" />
                                    <Label Text="{Binding Mesa, StringFormat='Mesa: {0}'}" FontSize="13" TextColor="#757575" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" Padding="12,6" BackgroundColor="#FF4B3A" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                    <Label Text="{Binding Estado}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                </Border>
                            </Grid>

                            <syncfusion:SfDataGrid ItemsSource="{Binding Detalles}"
                                                   AutoGenerateColumnsMode="None"
                                                   HeaderRowHeight="40" RowHeight="35"
                                                   SelectionMode="None" BackgroundColor="Transparent"
                                                   HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
                                <syncfusion:SfDataGrid.Columns>
                                    <syncfusion:DataGridTextColumn MappingName="Cantidad" Width="55" HeaderText="CANT" />
                                    <syncfusion:DataGridTextColumn MappingName="NombrePlatillo" HeaderText="PLATILLO" />
                                    <syncfusion:DataGridTextColumn MappingName="Comentarios" HeaderText="NOTAS" />
                                </syncfusion:SfDataGrid.Columns>
                            </syncfusion:SfDataGrid>

                            <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="12">
                                <Button Grid.Column="0" Text="PREPARAR" Clicked="OnEstadoClicked" CommandParameter="En preparación" BackgroundColor="#F5F5F5" TextColor="#1A1A1A" CornerRadius="12" FontAttributes="Bold" BorderWidth="1" BorderColor="#EEEEEE" />
                                <Button Grid.Column="1" Text="ENTREGADO" Clicked="OnEstadoClicked" CommandParameter="Entregado" BackgroundColor="#00C853" TextColor="White" CornerRadius="12" FontAttributes="Bold" />
                                <Button Grid.Column="2" Text="✕" Clicked="OnCancelarClicked" BackgroundColor="#FDECEA" TextColor="#FF4B3A" CornerRadius="12" WidthRequest="45" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
