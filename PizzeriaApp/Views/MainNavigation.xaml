<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="PizzeriaApp.Views.MainNavigation"
            FlyoutLayoutBehavior="Popover"
            Title="Pizzería TECNM">

    <FlyoutPage.Flyout>
        <ContentPage Title="Menú" BackgroundColor="{StaticResource Primary}">
            <ScrollView>
                <VerticalStackLayout x:Name="MenuContainer" Padding="20" Spacing="15">
                    <Image Source="pizzasteve.png" HeightRequest="100" HorizontalOptions="Center" Margin="0,0,0,20" />

                    <Label x:Name="lblNombreUsuario" 
                           Text="Bienvenido" 
                           TextColor="{StaticResource White}" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />

                </VerticalStackLayout>
            </ScrollView>
        </ContentPage>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="Cargando Sistema..." BackgroundColor="{StaticResource Secondary}">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                        <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" />
                        <Label Text="Preparando tu entorno..." TextColor="{StaticResource Tertiary}" />
                    </VerticalStackLayout>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>