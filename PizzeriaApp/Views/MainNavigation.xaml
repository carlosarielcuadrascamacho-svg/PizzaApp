<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:converters="clr-namespace:PizzeriaApp.Converters"
            x:Class="PizzeriaApp.Views.MainNavigation"
            FlyoutLayoutBehavior="Popover"
            Title="Pizzería TECNM">

    <FlyoutPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </FlyoutPage.Resources>

    <FlyoutPage.Flyout>
        <ContentPage Title="Menú" BackgroundColor="White">
            <Grid RowDefinitions="200, *, Auto">
                <!-- Header con Gradiente y Perfil -->
                <Grid Grid.Row="0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E53935" Offset="0.0" />
                            <GradientStop Color="#B71C1C" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,20" Spacing="5">
                        <Border WidthRequest="70" HeightRequest="70" Stroke="White" StrokeThickness="2" StrokeShape="RoundRectangle 35" HorizontalOptions="Start" BackgroundColor="White">
                            <Image x:Name="imgFlyoutPerfil" Source="pizzasteve.png" Aspect="AspectFill" />
                        </Border>
                        <Label x:Name="lblNombreUsuario" 
                               Text="Bienvenido" 
                               TextColor="White" 
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label x:Name="lblRol" 
                               Text="Miembro Activo" 
                               TextColor="#FFCDD2" 
                               FontSize="13" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Menú Opciones Dinámicas -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="MenuContainer" Padding="15,20,15,20" Spacing="5" />
                </ScrollView>

                <!-- Pie del Menú (Footer) -->
                <StackLayout Grid.Row="2" Padding="20">
                    <Label Text="Pizzería App Premium" TextColor="Gray" FontSize="12" HorizontalOptions="Center" />
                </StackLayout>
            </Grid>
        </ContentPage>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="Cargando Sistema..." BackgroundColor="{StaticResource Secondary}">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                        <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" />
                        <Label Text="Preparando tu entorno..." TextColor="{StaticResource Tertiary}" />
                    </VerticalStackLayout>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>