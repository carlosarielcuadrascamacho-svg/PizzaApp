<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.Orders"
             Title="Mi Carrito"
             BackgroundColor="#FCFCFC">

    <Grid RowDefinitions="*, Auto">
        
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20">
                <Label Text="Tus Delicias" FontSize="26" FontAttributes="Bold" TextColor="#333" Margin="0,0,0,20"/>

                <!-- Lista de carrito -->
                <CollectionView x:Name="ListaCarrito" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,10" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Frame Grid.Column="0" WidthRequest="60" HeightRequest="60" CornerRadius="10" Padding="0" IsClippedToBounds="True" HasShadow="False" BorderColor="Transparent" VerticalOptions="Center">
                                        <Image Source="{Binding Producto.ImagenUrl}" Aspect="AspectFill" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                        <Label Text="{Binding Producto.Nombre}" FontSize="16" FontAttributes="Bold" TextColor="#222"/>
                                        <Label Text="{Binding Subtotal, StringFormat='{0:C}'}" FontSize="14" TextColor="#E53935" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding Cantidad, StringFormat='x{0}'}" FontSize="16" FontAttributes="Bold" TextColor="#888" VerticalOptions="Center" Margin="0,0,10,0"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Aviso si está vacío -->
                <Label x:Name="lblVacio" Text="No tienes nada en el carrito." FontSize="16" TextColor="Gray" HorizontalOptions="Center" Margin="0,40,0,0" IsVisible="False"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Totales y Pagar -->
        <Frame Grid.Row="1" BackgroundColor="White" Padding="20,20,20,30" HasShadow="True" CornerRadius="30" Margin="0" BorderColor="Transparent">
            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Subtotal:" FontSize="16" TextColor="#666" />
                    <Label Grid.Column="1" x:Name="lblSubtotal" Text="$0.00" FontSize="16" FontAttributes="Bold" TextColor="#222" />
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Envío:" FontSize="16" TextColor="#666" />
                    <Label Grid.Column="1" Text="¡Gratis!" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" />
                </Grid>
                <BoxView HeightRequest="1" Color="#EEEEEE" />
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Total:" FontSize="22" FontAttributes="Bold" TextColor="#222" />
                    <Label Grid.Column="1" x:Name="lblTotal" Text="$0.00" FontSize="22" FontAttributes="Bold" TextColor="#E53935" />
                </Grid>

                <Button x:Name="btnConfirmar"
                        Text="Realizar Pedido"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="18"
                        CornerRadius="25"
                        HeightRequest="55"
                        Margin="0,10,0,0"
                        Clicked="OnConfirmarClicked" />
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>
