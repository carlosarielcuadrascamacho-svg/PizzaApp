<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="PizzeriaApp.Views.MenuAdmin"
             Title="Gestión de Pedidos en Vivo"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">

        <HorizontalStackLayout Grid.Row="0" Margin="20,20,20,10" Spacing="10" VerticalOptions="Center">
            <Label Text="🔴" FontSize="18" VerticalOptions="Center" >
                <Label.Triggers>
                    <EventTrigger Event="Loaded">
                        <EventTrigger.Actions>
                        </EventTrigger.Actions>
                    </EventTrigger>
                </Label.Triggers>
            </Label>
            <Label Text="Cola de Cocina (En Vivo)" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   TextColor="#333333" />
            <Picker x:Name="FiltroEstado" 
                    Title="Filtrar Pedidos"
                    Margin="20,0,0,0"
                    VerticalOptions="Center" 
                    SelectedIndexChanged="OnFiltroChanged">
                <Picker.Items>
                    <x:String>Activos</x:String>
                    <x:String>Completados</x:String>
                </Picker.Items>
            </Picker>
        </HorizontalStackLayout>

        <syncfusion:SfDataGrid Grid.Row="1"
                               x:Name="GridPedidos"
                               AutoGenerateColumnsMode="None"
                               ColumnWidthMode="Auto"
                               HeaderRowHeight="50"
                               RowHeight="70"
                               Margin="10">

            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTextColumn HeaderText="Fecha" 
                                               MappingName="Fecha" 
                                               Format="dd/MM HH:mm" />

                <syncfusion:DataGridTextColumn HeaderText="Estado" 
                                               MappingName="Estado" />

                <syncfusion:DataGridNumericColumn HeaderText="Total" 
                                                  MappingName="Total" 
                                                  Format="C" />

                <syncfusion:DataGridTemplateColumn HeaderText="Acción" MappingName="Id">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Text="Despachar" 
                                    BackgroundColor="#2E7D32" 
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    Margin="5"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnDespacharClicked"/>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>

            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>