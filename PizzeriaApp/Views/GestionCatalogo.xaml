<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.GestionCatalogo"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="Gestión de Catálogo" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label Text="Modifica platillos y disponibilidad" FontSize="13" TextColor="#757575" />
                </VerticalStackLayout>
                
                <Button Grid.Column="1" Text="+ NUEVO" Clicked="OnAgregarProductoClicked" BackgroundColor="#FF4B3A" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="45" Padding="15,0" />
            </Grid>
        </Border>

        <!-- Listado SCRUD -->
        <CollectionView Grid.Row="1" x:Name="ListaInventario" Margin="15,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="15" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEditarProductoTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            
                            <Border Grid.Column="0" WidthRequest="65" HeightRequest="65" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                <Image Source="{Binding ImagenBase64, Converter={StaticResource Base64Converter}}" Aspect="AspectFill" />
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="#1A1A1A"/>
                                <Label Text="{Binding Precio, StringFormat='{0:C}'}" FontSize="14" TextColor="#00C853" FontAttributes="Bold"/>
                                <Label Text="{Binding Categoria}" FontSize="11" TextColor="#757575" />
                            </VerticalStackLayout>

                            <Border Grid.Column="2" VerticalOptions="Center" Padding="12,6" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Activo}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#00C853" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Activo}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#FF4B3A" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label FontSize="10" FontAttributes="Bold" TextColor="White">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Activo}" Value="True">
                                            <Setter Property="Text" Value="ACTIVO" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Activo}" Value="False">
                                            <Setter Property="Text" Value="INACTIVO" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
