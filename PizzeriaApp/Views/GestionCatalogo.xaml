<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.GestionCatalogo"
             Title="Gestión de Catálogo"
             BackgroundColor="#FCFCFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="15" Padding="15" StrokeThickness="0" BackgroundColor="#FFF8E1" StrokeShape="RoundRectangle 15">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="🛠️" FontSize="32" VerticalOptions="Center"/>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Inventario Activo" FontSize="18" FontAttributes="Bold" TextColor="#B71C1C"/>
                    <Label Text="Alterna la disponibilidad real en la BD." FontSize="14" TextColor="Gray" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Lista de Productos para Activar/Desactivar -->
        <CollectionView Grid.Row="1" x:Name="ListaInventario" Margin="10,0,10,10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="15" CornerRadius="12" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="15">
                            <Frame Grid.Column="0" WidthRequest="60" HeightRequest="60" CornerRadius="8" IsClippedToBounds="True" HasShadow="False" BorderColor="Transparent" Padding="0" VerticalOptions="Center">
                                <Image Source="{Binding ImagenBase64, Converter={StaticResource Base64Converter}}" Aspect="AspectFill" />
                            </Frame>
                            
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="#222"/>
                                <Label Text="{Binding Precio, StringFormat='{0:C}'}" FontSize="14" TextColor="#B71C1C" FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Switch de Disponibilidad DB Real -->
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label Text="Público" FontSize="10" TextColor="Gray" HorizontalOptions="Center" />
                                <Switch IsToggled="{Binding Activo}" Toggled="OnDisponibilidadToggled" BindingContext="{Binding .}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
