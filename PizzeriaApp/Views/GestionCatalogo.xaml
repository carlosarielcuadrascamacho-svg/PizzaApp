<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.GestionCatalogo"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header Stitch Moderno -->
        <Border Grid.Row="0" Margin="25,30,25,10" Padding="0" BackgroundColor="Transparent" StrokeThickness="0">
            <VerticalStackLayout Spacing="5">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Intelligence Inventory" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                        <Label Text="Gestión de Catálogo" FontSize="28" FontAttributes="Bold" TextColor="#1A1A1A" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="+" FontSize="24" Clicked="OnAgregarProductoClicked" BackgroundColor="#FF4B3A" TextColor="White" Padding="0" CornerRadius="28" HeightRequest="56" WidthRequest="56" VerticalOptions="Start">
                        <Button.Shadow>
                            <Shadow Brush="#FF4B3A" Offset="0,4" Radius="10" Opacity="0.3" />
                        </Button.Shadow>
                    </Button>
                </Grid>

                <!-- Buscador Minimalista -->
                <Border Margin="0,15,0,0" Padding="15,0" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 20" HeightRequest="50">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" Margin="0,0,10,0" />
                        <Entry Grid.Column="1" x:Name="txtBusqueda" Placeholder="Buscar pizza o complemento..." TextChanged="OnBusquedaChanged" BackgroundColor="Transparent" TextColor="#1A1A1A" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Filtros de Categoría (Pills) -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,10,0,15">
            <HorizontalStackLayout x:Name="slCategorias" Padding="25,0" Spacing="10" />
        </ScrollView>

        <Grid Grid.Row="2">
            <!-- Skeleton Loader (Sólo visible durante la carga) -->
            <Grid x:Name="GridSkeleton" IsVisible="False" Padding="20,0">
                <VerticalStackLayout Spacing="15">
                    <Border HeightRequest="100" BackgroundColor="#E0E0E0" StrokeShape="RoundRectangle 20" Opacity="0.6" />
                    <Border HeightRequest="100" BackgroundColor="#E0E0E0" StrokeShape="RoundRectangle 20" Opacity="0.6" />
                    <Border HeightRequest="100" BackgroundColor="#E0E0E0" StrokeShape="RoundRectangle 20" Opacity="0.6" />
                </VerticalStackLayout>
            </Grid>

            <!-- Lista Real -->
            <CollectionView x:Name="ListaInventario" Margin="15,0,15,20" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="50" Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="🍕" FontSize="60" HorizontalOptions="Center" />
                        <Label Text="No encontramos productos" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" HorizontalOptions="Center" />
                        <Label Text="Intenta ajustar tu búsqueda o categoría" FontSize="14" TextColor="#757575" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 22">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,6" Radius="12" Opacity="0.06" />
                            </Border.Shadow>
                            
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                <!-- Imagen en miniatura premium -->
                                <Border Grid.Column="0" WidthRequest="75" HeightRequest="75" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                    <Image Source="{Binding ImagenBase64, Converter={StaticResource Base64Converter}}" Aspect="AspectFill">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding Activo}" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#1A1A1A" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Precio, StringFormat='{0:C}'}" FontSize="14" TextColor="#2E7D32" FontAttributes="Bold" />
                                    <Label Text="{Binding Categoria}" FontSize="11" TextColor="#757575" />
                                </VerticalStackLayout>

                                <!-- Panel de Acciones Rápidas -->
                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="8">
                                    <Switch IsToggled="{Binding Activo, Mode=TwoWay}" Toggled="OnStatusToggled" OnColor="#FF4B3A" ThumbColor="White" Scale="0.8" />
                                    <Button Text="EDITAR" Clicked="OnEditarProductoTapped" CommandParameter="{Binding .}" FontSize="9" FontAttributes="Bold" TextColor="#FF4B3A" BackgroundColor="#FFF2F0" CornerRadius="10" HeightRequest="30" Padding="10,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
