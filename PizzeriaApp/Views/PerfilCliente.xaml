<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.PerfilCliente"
             Title="Mi Cuenta"
             BackgroundColor="#F4F6F8">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto, *">
            <!-- Header -->
            <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Border HeightRequest="120" WidthRequest="120" StrokeShape="RoundRectangle 60" StrokeThickness="0" BackgroundColor="#F5F5F5" Margin="0,0,0,10">
                        <Image x:Name="imgPerfil" Source="{Binding FotoPerfil, Converter={StaticResource Base64Converter}}" Aspect="AspectFill" />
                    </Border>
                    <Button Text="CAMBIAR FOTO" Clicked="OnPickPhotoClicked" BackgroundColor="Transparent" TextColor="#B71C1C" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Info Card -->
            <Border Grid.Row="1" Margin="20,10,20,30" Padding="25" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="20">

                    <Label Text="INFORMACIÓN PERSONAL" FontSize="11" FontAttributes="Bold" TextColor="#B71C1C" CharacterSpacing="2" Margin="0,0,0,5" />

                    <VerticalStackLayout Spacing="5">
                        <Label Text="NOMBRE COMPLETO" FontSize="10" TextColor="#757575" CharacterSpacing="1" />
                        <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50">
                            <Entry x:Name="txtNombre" Placeholder="Tu nombre" BackgroundColor="Transparent" TextColor="#222" PlaceholderColor="#AAA" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="TELÉFONO" FontSize="10" TextColor="#757575" CharacterSpacing="1" />
                        <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50">
                            <Entry x:Name="txtTelefono" Placeholder="Teléfono" Keyboard="Telephone" BackgroundColor="Transparent" TextColor="#222" PlaceholderColor="#AAA" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="CORREO ELECTRÓNICO (SOLO LECTURA)" FontSize="10" TextColor="#757575" CharacterSpacing="1" />
                        <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F5F5F5" Padding="15,0" HeightRequest="50">
                            <Entry x:Name="txtEmail" IsReadOnly="True" BackgroundColor="Transparent" TextColor="#757575" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="DIRECCIÓN DE ENTREGA" FontSize="10" TextColor="#757575" CharacterSpacing="1" />
                        <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F9F9F9" Padding="15,10" HeightRequest="100">
                            <Editor x:Name="txtDireccion" Placeholder="Calle, número, colonia..." BackgroundColor="Transparent" TextColor="#222" PlaceholderColor="#AAA" AutoSize="TextChanges" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Save Action -->
                    <Button Text="ACTUALIZAR PERFIL" Clicked="OnUpdateProfileClicked" BackgroundColor="#B71C1C" TextColor="White" HeightRequest="60" CornerRadius="20" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
