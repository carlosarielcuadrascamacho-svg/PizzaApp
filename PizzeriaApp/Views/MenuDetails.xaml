<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.MenuDetails"
             Title="Detalles del Producto"
             BackgroundColor="White">

    <Grid RowDefinitions="300, *, Auto">
        
        <!-- Imagen Header -->
        <Image Grid.Row="0" 
               Source="{Binding ProductoMostrado.ImagenUrl}" 
               Aspect="AspectFill" 
               VerticalOptions="FillAndExpand" 
               HorizontalOptions="FillAndExpand" />

        <Frame Grid.Row="0" VerticalOptions="End" Margin="0,-20,0,0" CornerRadius="30" HasShadow="False" BackgroundColor="White" Padding="0" BorderColor="Transparent" HeightRequest="30" />

        <!-- Detalles del producto -->
        <ScrollView Grid.Row="1" Margin="0,-10,0,0">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="{Binding ProductoMostrado.Nombre}" FontSize="28" FontAttributes="Bold" TextColor="#222" />
                    <Label Grid.Column="1" Text="{Binding ProductoMostrado.Precio, StringFormat='{0:C}'}" FontSize="24" FontAttributes="Bold" TextColor="#E53935" VerticalOptions="Center"/>
                </Grid>

                <Label Text="{Binding ProductoMostrado.Descripcion}" FontSize="16" TextColor="#666" LineHeight="1.5" />

                <!-- Selector de Cantidad -->
                <Frame BackgroundColor="#F5F5F5" CornerRadius="15" Padding="15,5" HorizontalOptions="Center" Margin="0,30,0,0" BorderColor="Transparent">
                    <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                        <Button Text="-" FontSize="24" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="#333" Clicked="OnDisminuirClicked" />
                        <Label x:Name="lblCantidad" Text="1" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" TextColor="#333" />
                        <Button Text="+" FontSize="24" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="#E53935" Clicked="OnAumentarClicked" />
                    </HorizontalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Botón Inferior -->
        <Frame Grid.Row="2" BackgroundColor="White" Padding="20" HasShadow="True" BorderColor="Transparent" CornerRadius="0">
            <Button x:Name="btnAgregar"
                    Text="Añadir al carrito - $0.00" 
                    BackgroundColor="#E53935" 
                    TextColor="White" 
                    FontSize="18" 
                    FontAttributes="Bold"
                    CornerRadius="25" 
                    HeightRequest="55"
                    Clicked="OnConfirmarAgregarClicked" />
        </Frame>
    </Grid>
</ContentPage>
