<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.MenuDetails"
             Title="Detalles del Producto"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="380, *, Auto" BackgroundColor="White">
        
        <!-- Imagen Header Inmersiva -->
        <Grid Grid.Row="0">
            <Image Source="{Binding ProductoMostrado.ImagenBase64, Converter={StaticResource Base64Converter}}" 
                   Aspect="AspectFill" 
                   VerticalOptions="FillAndExpand" 
                   HorizontalOptions="FillAndExpand" />
            
            <!-- Overlay gradiente para los botones superiores -->
            <BoxView VerticalOptions="Start" HeightRequest="100">
                <BoxView.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#80000000" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Botón de Retroceso manual si fuera necesario (opcional) -->
        </Grid>

        <!-- Contenedor Redondeado de Contenido -->
        <Border Grid.Row="1" Margin="0,-40,0,0" Padding="0" StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 40,40,0,0">
            <ScrollView>
                <VerticalStackLayout Padding="30,40,30,30" Spacing="25">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="{Binding ProductoMostrado.Nombre}" FontSize="28" FontAttributes="Bold" TextColor="#1A1A1A" />
                            <Label Grid.Column="1" Text="{Binding ProductoMostrado.Precio, StringFormat='{0:C}'}" FontSize="24" FontAttributes="Bold" TextColor="#FF4B3A" />
                        </Grid>
                        <Label Text="{Binding ProductoMostrado.Categoria}" FontSize="12" TextColor="#FF4B3A" FontAttributes="Bold" CharacterSpacing="2" />
                    </VerticalStackLayout>

                    <Label Text="{Binding ProductoMostrado.Descripcion}" FontSize="16" TextColor="#757575" LineHeight="1.6" />

                    <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,10" />

                    <!-- Cantidad Selector -->
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center" Margin="0,10">
                        <Label Text="¿CUÁNTOS VAS A QUERER?" FontSize="10" FontAttributes="Bold" TextColor="#BDBDBD" HorizontalOptions="Center" CharacterSpacing="2" />
                        <Border BackgroundColor="#F8F9FA" StrokeThickness="0" StrokeShape="RoundRectangle 25" Padding="15,10" HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="40" VerticalOptions="Center">
                                <Button Text="-" FontSize="24" WidthRequest="60" HeightRequest="60" CornerRadius="30" 
                                        BackgroundColor="White" TextColor="#1A1A1A" Clicked="OnDisminuirClicked">
                                    <Button.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                                    </Button.Shadow>
                                </Button>
                                
                                <Label x:Name="lblCantidad" Text="1" FontSize="32" FontAttributes="Bold" VerticalOptions="Center" TextColor="#1A1A1A" WidthRequest="40" HorizontalTextAlignment="Center" />
                                
                                <Button Text="+" FontSize="24" WidthRequest="60" HeightRequest="60" CornerRadius="30" 
                                        BackgroundColor="#FF4B3A" TextColor="White" Clicked="OnAumentarClicked">
                                    <Button.Shadow>
                                        <Shadow Brush="#FF4B3A" Offset="0,8" Radius="15" Opacity="0.3" />
                                    </Button.Shadow>
                                </Button>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- Botón de Acción Inferior Premium -->
        <Border Grid.Row="2" Padding="25,20,25,30" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="15" Opacity="0.05" />
            </Border.Shadow>
            <Button x:Name="btnAgregar"
                    Text="Añadir al carrito • $0.00" 
                    BackgroundColor="#FF4B3A" 
                    TextColor="White" 
                    FontSize="18" 
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    CornerRadius="22" 
                    HeightRequest="65"
                    Clicked="OnConfirmarAgregarClicked">
                <Button.Shadow>
                    <Shadow Brush="#FF4B3A" Offset="0,10" Radius="20" Opacity="0.4" />
                </Button.Shadow>
            </Button>
        </Border>
    </Grid>
</ContentPage>
