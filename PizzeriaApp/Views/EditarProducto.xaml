<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.EditarProducto"
             Title="Editar Platillo"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="#F8F9FA">
        <Grid RowDefinitions="Auto, *" Padding="0,0,0,30">
            <!-- Header Stitch Premium -->
            <Border Grid.Row="0" Margin="25,30,25,10" Padding="0" BackgroundColor="Transparent" StrokeThickness="0">
                <VerticalStackLayout Spacing="4">
                    <Label Text="PRODUCT EDITOR" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                    <Label Text="Editar Platillo" FontSize="32" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label Text="Actualiza la información y disponibilidad" FontSize="14" TextColor="#757575" />
                </VerticalStackLayout>
            </Border>

            <!-- Form Card Premium -->
            <Border Grid.Row="1" Margin="20,10,20,0" Padding="25" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 30">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.05" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="25">
                    <!-- Imagen Upload Area Minimalista -->
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Border HeightRequest="150" WidthRequest="150" StrokeShape="RoundRectangle 75" StrokeThickness="0" BackgroundColor="#F5F5F7">
                            <Grid>
                                <Image x:Name="imgSelected" Source="placeholder_pizza.png" Aspect="AspectFill" />
                                <Border BackgroundColor="#CCFFFFFF" HeightRequest="40" WidthRequest="40" VerticalOptions="End" HorizontalOptions="End" Margin="0,0,5,5" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                                    <Label Text="📷" HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPickImageClicked" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </Border>
                        <Label Text="TAP PARA CAMBIAR IMAGEN" FontSize="9" HorizontalOptions="Center" TextColor="#757575" FontAttributes="Bold" CharacterSpacing="1" />
                    </VerticalStackLayout>

                    <!-- Fields Section -->
                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="NOMBRE DEL PRODUCTO" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" Margin="5,0"/>
                            <Border StrokeThickness="1" Stroke="#F0F0F0" StrokeShape="RoundRectangle 16" BackgroundColor="#FAFAFA" Padding="15,0" HeightRequest="54">
                                <Entry x:Name="txtNombre" Placeholder="Nombre de la pizza..." BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#BDBDBD" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="DESCRIPCIÓN DETALLADA" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" Margin="5,0"/>
                            <Border StrokeThickness="1" Stroke="#F0F0F0" StrokeShape="RoundRectangle 16" BackgroundColor="#FAFAFA" Padding="15,10" HeightRequest="110">
                                <Editor x:Name="txtDescripcion" Placeholder="Ingredientes, tamaño..." BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#BDBDBD" AutoSize="TextChanges" />
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="PRECIO ($)" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" Margin="5,0"/>
                                <Border StrokeThickness="1" Stroke="#F0F0F0" StrokeShape="RoundRectangle 16" BackgroundColor="#FAFAFA" Padding="15,0" HeightRequest="54">
                                    <Entry x:Name="txtPrecio" Placeholder="0.00" Keyboard="Numeric" BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#BDBDBD" VerticalOptions="Center" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="CATEGORÍA" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="1.5" Margin="5,0"/>
                                <Border StrokeThickness="1" Stroke="#F0F0F0" StrokeShape="RoundRectangle 16" BackgroundColor="#FAFAFA" HeightRequest="54">
                                    <Picker x:Name="pickCategoria" Title="Elegir..." BackgroundColor="Transparent" TextColor="#1A1A1A" TitleColor="#BDBDBD" Margin="10,0">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>Pizzas</x:String>
                                                <x:String>Bebidas</x:String>
                                                <x:String>Postres</x:String>
                                                <x:String>Entradas</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Disponibilidad Panel Premium -->
                        <Border Margin="0,5,0,0" Padding="15" BackgroundColor="#FFF9F9" StrokeThickness="1" Stroke="#FFE5E2" StrokeShape="RoundRectangle 16">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="VISIBILIDAD EN MENÚ" FontSize="11" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="0.5" />
                                    <Label Text="Determina si el cliente puede pedirlo" FontSize="11" TextColor="#8D6E63" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="swActivo" OnColor="#FF4B3A" ThumbColor="White" Scale="0.9" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Acciones -->
                    <Button x:Name="btnGuardar" 
                            Text="GUARDAR CAMBIOS" 
                            Clicked="OnGuardarClicked" 
                            BackgroundColor="#1A1A1A" 
                            TextColor="White" 
                            HeightRequest="64" 
                            CornerRadius="32" 
                            FontAttributes="Bold" 
                            FontSize="16" 
                            Margin="0,15,0,0">
                        <Button.Shadow>
                            <Shadow Brush="Black" Offset="0,8" Radius="15" Opacity="0.15" />
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
