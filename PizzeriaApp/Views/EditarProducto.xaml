<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.EditarProducto"
             Title="Editar Platillo"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto, *">
            <!-- Header Stitch -->
            <Border Grid.Row="0" Margin="20,25,20,10" Padding="20" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="5">
                    <Label Text="Editor de Platillo" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label Text="Actualiza la información del producto" FontSize="13" TextColor="#757575" />
                </VerticalStackLayout>
            </Border>

            <!-- Form Card Stitch -->
            <Border Grid.Row="1" Margin="20,10,20,30" Padding="25" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="25">

                    <!-- Imagen Upload Area -->
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border HeightRequest="160" WidthRequest="160" StrokeShape="RoundRectangle 80" StrokeThickness="0" BackgroundColor="#F8F9FA">
                            <Image x:Name="imgSelected" Source="placeholder_pizza.png" Aspect="AspectFill" />
                        </Border>
                        <Button Text="CAMBIAR FOTO" Clicked="OnPickImageClicked" BackgroundColor="#F5F5F5" TextColor="#FF4B3A" FontSize="11" FontAttributes="Bold" CornerRadius="12" HeightRequest="45" BorderWidth="1" BorderColor="#EEEEEE" />
                    </VerticalStackLayout>

                    <!-- Fields -->
                    <VerticalStackLayout Spacing="15">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="NOMBRE DEL PRODUCTO" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                            <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F8F9FA" Padding="15,0" HeightRequest="50">
                                <Entry x:Name="txtNombre" Placeholder="Nombre" BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#AAA" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="DESCRIPCIÓN" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                            <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F8F9FA" Padding="15,10" HeightRequest="100">
                                <Editor x:Name="txtDescripcion" Placeholder="Ingredientes..." BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#AAA" AutoSize="TextChanges" />
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="PRECIO" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                                <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F8F9FA" Padding="15,0" HeightRequest="50">
                                    <Entry x:Name="txtPrecio" Placeholder="0.00" Keyboard="Numeric" BackgroundColor="Transparent" TextColor="#1A1A1A" PlaceholderColor="#AAA" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="CATEGORÍA" FontSize="10" FontAttributes="Bold" TextColor="#FF4B3A" CharacterSpacing="2" />
                                <Border StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12" BackgroundColor="#F8F9FA" HeightRequest="50">
                                    <Picker x:Name="pickCategoria" Title="Seleccionar" BackgroundColor="Transparent" TextColor="#1A1A1A" TitleColor="#AAA">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>Pizzas</x:String>
                                                <x:String>Bebidas</x:String>
                                                <x:String>Postres</x:String>
                                                <x:String>Entradas</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Disponibilidad Switch -->
                        <Border Padding="15" BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#EEEEEE" StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="DISPONIBILIDAD" FontSize="11" FontAttributes="Bold" TextColor="#FF4B3A" />
                                    <Label Text="¿Aparece en el menú del cliente?" FontSize="11" TextColor="#757575" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="swActivo" OnColor="#FF4B3A" ThumbColor="White" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Save Action -->
                    <Button x:Name="btnGuardar" Text="GUARDAR CAMBIOS" Clicked="OnGuardarClicked" BackgroundColor="#FF4B3A" TextColor="White" HeightRequest="60" CornerRadius="25" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
