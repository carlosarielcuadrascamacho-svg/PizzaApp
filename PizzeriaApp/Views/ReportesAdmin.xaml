<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="PizzeriaApp.Views.ReportesAdmin"
             Title="Panel Directivo"
             BackgroundColor="#FCFCFC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Desempeño del Restaurante" FontSize="26" FontAttributes="Bold" TextColor="#1565C0" />
            
            <!-- Cards Resumen Reales -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Frame Grid.Column="0" BackgroundColor="#E3F2FD" Padding="15" CornerRadius="12" HasShadow="False" BorderColor="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Ingresos Reales" TextColor="#1565C0" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="lblIngresos" Text="$0.00" TextColor="#0D47A1" FontSize="20" FontAttributes="Bold" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>
                
                <Frame Grid.Column="1" BackgroundColor="#E8F5E9" Padding="15" CornerRadius="12" HasShadow="False" BorderColor="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Ventas Directas" TextColor="#2E7D32" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="lblPlatillos" Text="0 Platillos" TextColor="#1B5E20" FontSize="20" FontAttributes="Bold" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Syncfusion CircularChart Platillos Populares -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="20" HasShadow="True" BorderColor="Transparent" Margin="0,15,0,0">
                <VerticalStackLayout>
                    <Label Text="Platillos Estrella" FontSize="16" FontAttributes="Bold" TextColor="#333" Margin="0,0,0,10"/>
                    <chart:SfCircularChart HeightRequest="300">
                        <chart:SfCircularChart.Legend>
                            <chart:ChartLegend Placement="Top" />
                        </chart:SfCircularChart.Legend>

                        <chart:DoughnutSeries x:Name="PieRanking" 
                                              XBindingPath="Concepto" 
                                              YBindingPath="Cantidad" 
                                              ShowDataLabels="True">
                            <chart:DoughnutSeries.DataLabelSettings>
                                <chart:CircularDataLabelSettings LabelPlacement="Outer" />
                            </chart:DoughnutSeries.DataLabelSettings>
                        </chart:DoughnutSeries>
                    </chart:SfCircularChart>
                </VerticalStackLayout>
            </Frame>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
