<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.MenuClient"
             Title="Nuestro Menú"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *, Auto">
        <!-- Header -->
        <Border Grid.Row="0" Margin="15" Padding="15" StrokeThickness="0" BackgroundColor="#FF4B3A" StrokeShape="RoundRectangle 15">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="🍕" FontSize="32" VerticalOptions="Center"/>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="¿Qué se te antoja hoy?" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Encuentra tu platillo favorito" FontSize="14" TextColor="#FFEBEE" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Category Filters -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="15,0,15,10">
            <HorizontalStackLayout Spacing="10" x:Name="slCategorias">
                <!-- Dynamically populated in CodeBehind -->
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Pizzas List -->
        <CollectionView Grid.Row="2" x:Name="ListaProductos" SelectionMode="Single" SelectionChanged="OnProductoSeleccionado" Margin="10,0,10,10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="15" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="0" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 20" HeightRequest="250">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
                        </Border.Shadow>
                        <Grid RowDefinitions="120, Auto, Auto, *">
                            <Border Grid.Row="0" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0" HeightRequest="120">
                                <Image Source="{Binding ImagenBase64, Converter={StaticResource Base64Converter}}" Aspect="AspectFill" BackgroundColor="#F8F9FA" />
                            </Border>
                                   
                            <Label Grid.Row="1" Padding="15,10,15,0" Text="{Binding Nombre}" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                            <Label Grid.Row="2" Padding="15,2,15,0" Text="{Binding Descripcion}" FontSize="12" TextColor="#757575" LineBreakMode="TailTruncation" MaxLines="2" />
                            
                            <Grid Grid.Row="3" Padding="15,0,15,15" VerticalOptions="End" ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="{Binding Precio, StringFormat='{0:C}'}" FontSize="16" TextColor="#00C853" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="+" FontSize="20" FontAttributes="Bold" BackgroundColor="#FF4B3A" TextColor="White" CornerRadius="20" WidthRequest="40" HeightRequest="40" Padding="0" Margin="0" Clicked="OnAgregarCarritoClicked" BindingContext="{Binding .}" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom Cart Bar -->
        <Border Grid.Row="3" Margin="15,5,15,15" Padding="15" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 20" IsVisible="True" x:Name="ContenedorCarrito">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label x:Name="lblCartTotal" Text="$0.00" FontSize="18" FontAttributes="Bold" TextColor="#00C853" />
                    <Label x:Name="lblCartItems" Text="0 artículos" FontSize="12" TextColor="#757575" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Confirmar Orden" FontAttributes="Bold" BackgroundColor="#FF4B3A" TextColor="White" CornerRadius="12" HeightRequest="45" Clicked="OnConfirmarOrdenClicked" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>