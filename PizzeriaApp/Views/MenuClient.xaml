<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.MenuClient"
             Title="Nuestro Menú"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:Base64ToImageConverter x:Key="Base64Converter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" BackgroundColor="#FDFDFD">
        
        <!-- Header con Buscador -->
        <VerticalStackLayout Grid.Row="0" Padding="20,15,20,10" Spacing="15" BackgroundColor="White">
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Hola, ¡Bienvenido!" FontSize="14" TextColor="#757575" />
                    <Label Text="¿Qué vas a pedir hoy? 🍕" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                </VerticalStackLayout>
                <Image Grid.Column="1" Source="pizzasteve.png" HeightRequest="45" WidthRequest="45" Aspect="AspectFit" />
            </Grid>

            <!-- Barra de Búsqueda -->
            <Border StrokeThickness="0" BackgroundColor="#F2F2F2" StrokeShape="RoundRectangle 15" HeightRequest="50">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔍" VerticalOptions="Center" Margin="15,0,10,0" Opacity="0.5" />
                    <Entry Grid.Column="1" x:Name="txtBusqueda" Placeholder="Buscar pizza, refresco..." 
                           TextColor="#1A1A1A" PlaceholderColor="#AAA" FontSize="14" 
                           VerticalOptions="Center" Margin="0,0,15,0" 
                           TextChanged="OnSearchTextChanged" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Categorías (Horizontal Scroll) -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,5,0,15">
            <HorizontalStackLayout Spacing="12" Padding="20,0" x:Name="slCategorias">
                <!-- Se llenará desde C# con un diseño de botones 'Pill' -->
            </HorizontalStackLayout>
        </ScrollView>

        <Label Grid.Row="2" Text="Populares para ti" FontSize="18" FontAttributes="Bold" Margin="20,0,20,10" TextColor="#1A1A1A" />

        <!-- Skeleton Loader (Solo visible mientras carga) -->
        <Grid Grid.Row="3" x:Name="GridSkeleton" Margin="10,0" IsVisible="True">
            <CollectionView ItemsSource="{Binding .}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="0" BackgroundColor="#F2F2F2" StrokeThickness="0" StrokeShape="RoundRectangle 24" HeightRequest="210" Opacity="0.6" x:Name="SkeletonCard">
                            <!-- Efecto de pulso en C# -->
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Cuadrícula de Productos (2 Columnas) -->
        <CollectionView Grid.Row="3" x:Name="ListaProductos" SelectionMode="Single" SelectionChanged="OnProductoSeleccionado" Margin="10,0" IsVisible="False">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0" BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 24" HeightRequest="210">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.08" />
                        </Border.Shadow>
                        <Grid RowDefinitions="*, Auto">
                            <!-- Imagen del Producto -->
                            <Grid Grid.Row="0">
                                <Image Source="{Binding ImagenBase64, Converter={StaticResource Base64Converter}}" 
                                       Aspect="AspectFill"
                                       BackgroundColor="#F5F5F5" />
                                
                                <Border BackgroundColor="#CC1A1A1A" StrokeShape="RoundRectangle 8" 
                                        HorizontalOptions="Start" VerticalOptions="Start" 
                                        Margin="10" Padding="8,3" StrokeThickness="0">
                                    <Label Text="🔥" FontSize="10" />
                                </Border>
                            </Grid>
                                   
                            <!-- Info del producto -->
                            <VerticalStackLayout Grid.Row="1" Padding="12,10" Spacing="4">
                                <Label Text="{Binding Nombre}" FontSize="14" FontAttributes="Bold" TextColor="#1A1A1A" MaxLines="1" LineBreakMode="TailTruncation" />
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding Precio, StringFormat='{0:C}'}" FontSize="13" TextColor="#FF4B3A" FontAttributes="Bold" VerticalOptions="Center"/>
                                    <Button Grid.Column="1" Text="+" HeightRequest="30" WidthRequest="30" CornerRadius="10" Padding="0" FontSize="16"
                                            BackgroundColor="#F5F5F5" TextColor="#FF4B3A" Clicked="OnAgregarCarritoClicked" BindingContext="{Binding .}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Barra de Carrito Flotante -->
        <Border Grid.Row="4" Margin="20,10,20,20" Padding="15" BackgroundColor="#1A1A1A" 
                StrokeThickness="0" StrokeShape="RoundRectangle 24" 
                IsVisible="False" x:Name="ContenedorCarrito">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="15" Opacity="0.3" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
                <HorizontalStackLayout Grid.Column="0" Spacing="15" VerticalOptions="Center">
                    <Border BackgroundColor="#FF4B3A" HeightRequest="40" WidthRequest="40" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                        <Label x:Name="lblCartItems" Text="0" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Tu Pedido" FontSize="12" TextColor="#BDBDBD" />
                        <Label x:Name="lblCartTotal" Text="$0.00" FontSize="16" FontAttributes="Bold" TextColor="White" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                
                <Button Grid.Column="1" Text="Ver Carrito ›" FontAttributes="Bold" BackgroundColor="#FF4B3A" 
                        TextColor="White" CornerRadius="14" HeightRequest="45" Padding="20,0" 
                        Clicked="OnConfirmarOrdenClicked" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>