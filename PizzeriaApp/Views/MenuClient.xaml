<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzeriaApp.Views.MenuClient"
             Title="Realizar Pedido"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <Label Text="🍕 Promoción del Día" 
               FontSize="24" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />

        <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Label Text="Pizza Pepperoni Grande" FontSize="18" FontAttributes="Bold"/>
                <Label Text="Incluye orilla de queso y un refresco de 2L." TextColor="Gray" />
                <Label Text="$250.00" FontSize="22" TextColor="DarkGreen" FontAttributes="Bold" HorizontalOptions="End"/>
            </VerticalStackLayout>
        </Frame>

        <Button x:Name="btnOrdenar"
                Text="Confirmar y Ordenar"
                BackgroundColor="#E53935"
                TextColor="White"
                FontSize="18"
                CornerRadius="25"
                HeightRequest="55"
                Clicked="OnOrdenarClicked" />

    </VerticalStackLayout>
</ContentPage>